{
  "version": 1,
  "editor": {
    "vimMode": false
  },
  "display": {
    "showLineNumbers": false,
    "showThinkingBlocks": false,
    "showStatusIndicators": false,
    "showStatusLineRunningTime": false
  },
  "notifications": true,
  "hints": true,
  "modelSlashCommands": true,
  "rewind": true,
  "hasChangedDefaultModel": false,
  "permissions": {
    "allow": [
      "Shell(ls)"
    ],
    "deny": [
      "Shell(rm -rf /)",
      "Shell(rm -rf ~)",
      "Shell(sudo rm)",
      "Shell(git push --force)",
      "Shell(git push -f)",
      "Shell(git filter-branch)",
      "Shell(mkfs)",
      "Shell(dd if=)"
    ]
  },
  "approvalMode": "allowlist",
  "autoAcceptWebSearch": false,
  "sandbox": {
    "mode": "enabled",
    "networkAccess": "user_config_with_defaults"
  },
  "runEverythingSettingsPromptStreak": 0,
  "network": {
    "useHttp1ForAgent": false
  },
  "attribution": {
    "attributeCommitsToAgent": true,
    "attributePRsToAgent": true
  }
}
