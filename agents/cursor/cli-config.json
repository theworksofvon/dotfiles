{
  "version": 1,
  "editor": {
    "vimMode": false
  },
  "display": {
    "showLineNumbers": false,
    "showThinkingBlocks": false,
    "showStatusIndicators": false,
    "showStatusLineRunningTime": false
  },
  "notifications": true,
  "hints": true,
  "modelSlashCommands": true,
  "rewind": true,
  "hasChangedDefaultModel": false,
  "permissions": {
    "allow": [
      "Shell(ls)"
    ],
    "deny": [
      "Shell(brew cleanup)",
      "Shell(brew remove)",
      "Shell(brew uninstall)",
      "Shell(cargo uninstall)",
      "Shell(dd if=)",
      "Shell(docker system prune)",
      "Shell(docker volume rm)",
      "Shell(gh repo delete)",
      "Shell(git filter-branch)",
      "Shell(git push --force)",
      "Shell(git push -f)",
      "Shell(mise implode)",
      "Shell(mise uninstall)",
      "Shell(mkfs)",
      "Shell(npm uninstall)",
      "Shell(pip uninstall)",
      "Shell(pnpm remove)",
      "Shell(rm -rf /)",
      "Shell(rm -rf ~)",
      "Shell(security delete-generic-password)",
      "Shell(sudo rm)",
      "Shell(terraform destroy)"
    ]
  },
  "approvalMode": "allowlist",
  "autoAcceptWebSearch": false,
  "sandbox": {
    "mode": "enabled",
    "networkAccess": "user_config_with_defaults"
  },
  "runEverythingSettingsPromptStreak": 0,
  "network": {
    "useHttp1ForAgent": false
  },
  "attribution": {
    "attributeCommitsToAgent": true,
    "attributePRsToAgent": true
  }
}
