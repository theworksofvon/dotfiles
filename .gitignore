# backups created by install.sh
*.bak

# machine-local overrides (not shared)
zsh/zshrc.local
mise/config.local.toml
claude/settings.local.json

# macOS
.DS_Store

# LazyVim runtime state (plugins are restored from lazy-lock.json)
nvim/lazyvim.json

# account identifiers are machine-local (see accounts.example.json)
config/claude-account/accounts.json

# codex rewrites config.toml (marketplace timestamps, local runtime paths)
agents/codex/config.toml

# claude code rewrites settings.json (plugins, model, hooks installed by other
# tools), and the paths it writes are absolute
agents/claude/settings.json

# personal git identity
.gitconfig.local
