# Ghostty
# Font: the "Mono" Nerd Font variant keeps icons single-width so the prompt
# never renders oversized or misaligned.
font-family = "JetBrainsMono Nerd Font Mono"
font-size = 14

theme = "tokyonight"
background-opacity = 0.96
window-padding-x = 12
window-padding-y = 10
cursor-style = block
mouse-hide-while-typing = true

# ── scrollback and selection ──────────────────────
scrollback-limit = 10000000     # ~10MB; agent sessions produce a lot of output
copy-on-select = clipboard
window-save-state = always

# ── shell integration ─────────────────────────────
# Enables jumping between prompts, working-directory inheritance in new
# splits, and marking command output. zshrc re-sources this inside tmux,
# where the automatic injection doesn't reach.
shell-integration = detect
shell-integration-features = cursor,sudo,title

# ── keybindings ───────────────────────────────────
# Splits, mirroring the tmux bindings so the muscle memory transfers.
keybind = cmd+d=new_split:right
keybind = cmd+shift+d=new_split:down
keybind = cmd+opt+left=goto_split:left
keybind = cmd+opt+right=goto_split:right
keybind = cmd+opt+up=goto_split:up
keybind = cmd+opt+down=goto_split:down
keybind = cmd+shift+enter=toggle_split_zoom

# Jump to the previous prompt — useful for finding where a long agent run began.
keybind = cmd+up=jump_to_prompt:-1
keybind = cmd+down=jump_to_prompt:1

# Clear scrollback outright rather than just scrolling past it.
keybind = cmd+k=clear_screen
