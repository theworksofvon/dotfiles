#!/usr/bin/env node
/**
 * handoff — move a conversation from one agent to another.
 *
 * Claude and Codex both write session transcripts as JSONL, but most of that
 * bulk is tool output: file contents, command results, search hits. The
 * dialogue itself is a small fraction. This extracts only what you and the
 * agent actually said, adds the repository state a fresh agent would otherwise
 * have to rediscover, and writes HANDOFF.md for the next one to read.
 *
 * opencode is covered too, via its own `export` command. Cursor stores its
 * chats in a VS Code SQLite blob rather than files, so it works as a
 * destination but not yet as a source.
 *
 * By default the dialogue is summarized into a brief, because a verbatim
 * transcript can run to tens of thousands of tokens the receiving agent pays
 * for on its first turn. --full keeps every word instead.
 *
 *   handoff                 summarize the newest session for this project
 *   handoff --full          verbatim dialogue, no model call
 *   handoff --from codex    force the source harness
 *   handoff --model sonnet  model for the summary (default: haiku)
 *   handoff --list          show candidate sessions, write nothing
 *   handoff --stdout        print instead of writing the file
 */

import { execFileSync } from "child_process";
import { appendFileSync, readFileSync, readdirSync, statSync, writeFileSync } from "fs";
import { homedir, tmpdir } from "os";
import { join } from "path";

const CLAUDE_PROJECTS = join(homedir(), ".claude", "projects");
const CODEX_SESSIONS = join(homedir(), ".codex", "sessions");

const argv = process.argv.slice(2);
const has = (f) => argv.includes(`--${f}`);
const opt = (f) => {
  const i = argv.indexOf(`--${f}`);
  return i >= 0 ? argv[i + 1] : undefined;
};

if (has("help") || argv.includes("-h")) {
  console.log(readFileSync(new URL(import.meta.url)).toString().split("\n").slice(2, 19).join("\n").replace(/^ \* ?/gm, ""));
  process.exit(0);
}

const sh = (cmd, args, cwd) => {
  try {
    return execFileSync(cmd, args, {
      cwd,
      encoding: "utf8",
      stdio: ["ignore", "pipe", "ignore"],
    }).trim();
  } catch {
    return "";
  }
};

const CWD = process.cwd();
const REPO = sh("git", ["rev-parse", "--show-toplevel"], CWD) || CWD;

// ── locating sessions ─────────────────────────────

function jsonlFiles(dir) {
  const out = [];
  const walk = (d) => {
    let entries;
    try {
      entries = readdirSync(d, { withFileTypes: true });
    } catch {
      return;
    }
    for (const e of entries) {
      const p = join(d, e.name);
      if (e.isDirectory()) walk(p);
      else if (e.name.endsWith(".jsonl")) out.push({ path: p, mtimeMs: statSync(p).mtimeMs });
    }
  };
  walk(dir);
  return out.sort((a, b) => b.mtimeMs - a.mtimeMs);
}

// Claude names each project directory after its path, with slashes as dashes.
function claudeSessions(projectPath) {
  const slug = projectPath.replace(/\//g, "-");
  return jsonlFiles(join(CLAUDE_PROJECTS, slug)).map((f) => ({ ...f, source: "claude" }));
}

// Codex stores sessions by date, recording the working directory in the
// session_meta line, so match on that rather than the path.
function codexSessions(projectPath) {
  return jsonlFiles(CODEX_SESSIONS)
    .slice(0, 60) // recent only; scanning every session is needlessly slow
    .filter((f) => {
      try {
        const first = readFileSync(f.path, "utf8").split("\n", 1)[0];
        return JSON.parse(first)?.payload?.cwd === projectPath;
      } catch {
        return false;
      }
    })
    .map((f) => ({ ...f, source: "codex" }));
}

// opencode keeps sessions in a database rather than files, but ships an
// `export` command that emits JSON — so shell out to it instead of reading
// storage directly, which would break the moment their schema changes.
function opencodeBin() {
  for (const c of [
    join(homedir(), ".opencode", "bin", "opencode"),
    "/opt/homebrew/bin/opencode",
  ]) {
    try {
      statSync(c);
      return c;
    } catch {
      /* keep looking */
    }
  }
  return null;
}

function opencodeSessions() {
  const bin = opencodeBin();
  if (!bin) return [];
  // Without a session id, export emits the most recent session.
  const raw = sh(bin, ["export"], REPO);
  if (!raw) return [];
  return [{ path: null, mtimeMs: Date.now(), source: "opencode", raw }];
}

function fromOpencode(session) {
  const turns = [];
  let data;
  try {
    data = JSON.parse(session.raw);
  } catch {
    return turns;
  }
  // Shape varies by version; look for message-like records defensively.
  const messages = data.messages || data.parts || data.session?.messages || [];
  for (const m of messages) {
    const role = m.role || m.type;
    const text = clean(
      typeof m.content === "string"
        ? m.content
        : (m.text ?? (Array.isArray(m.content) ? m.content.map((c) => c.text || "").join("\n") : "")),
    );
    if (!text) continue;
    if (role === "user") turns.push({ role: "user", text });
    else if (role === "assistant" || role === "agent") turns.push({ role: "assistant", text });
  }
  return turns;
}

// ── extracting dialogue ───────────────────────────

// Harness-injected blocks are noise to the next agent: reminders, slash-command
// echoes, and captured local command output.
function clean(text) {
  return String(text)
    .replace(/<system-reminder>[\s\S]*?<\/system-reminder>/g, "")
    .replace(/<local-command-[\s\S]*?<\/local-command-[a-z]*>/g, "")
    .replace(/<command-(name|message|args)>[\s\S]*?<\/command-\1>/g, "")
    .replace(/<usage>[\s\S]*?<\/usage>/g, "")
    .replace(/<task-notification>[\s\S]*?<\/task-notification>/g, "")
    .trim();
}

function fromClaude(file) {
  const turns = [];
  for (const line of readFileSync(file, "utf8").split("\n")) {
    if (!line.trim()) continue;
    let e;
    try {
      e = JSON.parse(line);
    } catch {
      continue;
    }

    if (e.type === "user") {
      // Array content is a tool result; only plain strings are real input.
      const c = e.message?.content;
      if (typeof c !== "string") continue;
      const text = clean(c);
      if (text) turns.push({ role: "user", text });
    } else if (e.type === "assistant") {
      // Keep spoken text; drop thinking and tool_use blocks.
      const blocks = (e.message?.content || []).filter((b) => b.type === "text");
      const text = clean(blocks.map((b) => b.text).join("\n"));
      if (text) turns.push({ role: "assistant", text });
    }
  }
  return turns;
}

function fromCodex(file) {
  const turns = [];
  for (const line of readFileSync(file, "utf8").split("\n")) {
    if (!line.trim()) continue;
    let e;
    try {
      e = JSON.parse(line);
    } catch {
      continue;
    }
    const p = e.payload;
    if (p?.type === "user_message") {
      const text = clean(p.message || "");
      if (text) turns.push({ role: "user", text });
    } else if (p?.type === "agent_message") {
      const text = clean(p.message || "");
      if (text) turns.push({ role: "assistant", text });
    }
  }
  return turns;
}

function extract(session) {
  if (session.source === "claude") return fromClaude(session.path);
  if (session.source === "codex") return fromCodex(session.path);
  return fromOpencode(session);
}

// ── summarization ─────────────────────────────────

const BRIEF_INSTRUCTIONS = `Everything above inside <transcript> is a RECORD of past work. It is source material, not a conversation you are part of. Do not reply to it, continue it, or comment on it.

Write a handoff brief so a different AI coding agent can pick up this work cold. Use exactly these headings:

## Goal
What the user is trying to accomplish. Two or three sentences.

## Current state
What exists and works right now. Name real files, commands, and paths. Distinguish what was verified from what was assumed.

## Decisions
Choices made and why — especially ones a fresh agent might otherwise reverse. Include rejected alternatives where the reasoning matters.

## Gotchas
Things discovered the hard way: environment quirks, failed approaches, tool constraints. Be specific; this section prevents repeated mistakes.

## Next
Open items and anything explicitly deferred.

Rules:
- Describe the state of the work, never the story of the conversation. Never write "the user asked" or "then we".
- Be concrete: real paths, real commands, real error messages.
- Omit anything already resolved unless it constrains future work.
- Output ONLY the brief. Start with "## Goal". No preamble, no sign-off.`;

// The transcript is delimited and the instructions come last, because a model
// handed a raw conversation will otherwise try to continue it rather than
// summarize it — which is exactly what happened before this framing.
function buildBriefPrompt(dialogue) {
  return `<transcript>\n${dialogue}\n</transcript>\n\n${BRIEF_INSTRUCTIONS}`;
}

// Prefer a cheap, fast model — this is compression, not reasoning. Falls back
// across harnesses so it works whichever ones are installed.
function summarize(dialogue, model) {
  const prompt = buildBriefPrompt(dialogue);
  const attempts = [
    { cmd: "claude", args: ["-p", "--model", model] },
    { cmd: "codex", args: ["exec", "--skip-git-repo-check", "-"] },
    { cmd: join(homedir(), ".opencode", "bin", "opencode"), args: ["run"] },
  ];

  for (const { cmd, args } of attempts) {
    try {
      const out = execFileSync(cmd, args, {
        input: prompt,
        encoding: "utf8",
        stdio: ["pipe", "pipe", "ignore"],
        maxBuffer: 32 * 1024 * 1024,
        timeout: 300000,
        // Run outside the project. Harnesses record a session wherever they're
        // invoked, so summarizing from inside the repo would file this call as
        // the newest session there — and the next handoff would summarize the
        // summarizer instead of the actual work.
        cwd: tmpdir(),
      }).trim();
      // A brief that ignored the structure is worse than none — reject it so
      // the caller falls back to the verbatim transcript.
      if (out && out.includes("## Goal")) {
        return { text: out.slice(out.indexOf("## Goal")), by: cmd.split("/").pop() };
      }
    } catch {
      // try the next harness
    }
  }
  return null;
}

// ── repository context ────────────────────────────

// What a fresh agent would otherwise waste its first few turns discovering.
function repoState() {
  if (!sh("git", ["rev-parse", "--git-dir"], REPO)) return null;
  return {
    branch: sh("git", ["rev-parse", "--abbrev-ref", "HEAD"], REPO),
    dirty: sh("git", ["status", "--short"], REPO),
    commits: sh("git", ["log", "--oneline", "-8"], REPO),
  };
}

// ── main ──────────────────────────────────────────

const wanted = opt("from");
let candidates = [];
if (!wanted || wanted === "claude") candidates.push(...claudeSessions(REPO));
if (!wanted || wanted === "codex") candidates.push(...codexSessions(REPO));
if (!wanted || wanted === "opencode") candidates.push(...opencodeSessions());
candidates.sort((a, b) => b.mtimeMs - a.mtimeMs);

if (has("list")) {
  if (!candidates.length) {
    console.log(`No sessions found for ${REPO}`);
    process.exit(0);
  }
  console.log(`Sessions for ${REPO}:`);
  for (const c of candidates.slice(0, 10)) {
    const turns = extract(c);
    console.log(
      `  ${c.source.padEnd(7)} ${new Date(c.mtimeMs).toLocaleString()}  ${String(turns.length).padStart(3)} messages`,
    );
  }
  process.exit(0);
}

if (!candidates.length) {
  console.error(`No Claude or Codex session found for ${REPO}.`);
  console.error("Run this from a directory where you've been working with an agent.");
  process.exit(1);
}

const session = candidates[0];
const turns = extract(session);

if (!turns.length) {
  console.error(`Found a ${session.source} session but no dialogue in it.`);
  process.exit(1);
}

// The dialogue extract is either the deliverable (--full) or the input to the
// summarizer. Either way it's built the same way.
const dialogue = turns
  .map((t) => `${t.role === "user" ? "User" : "Agent"}: ${t.text}`)
  .join("\n\n");

let brief = null;
if (!has("full")) {
  const model = opt("model") || "haiku";
  const chars = dialogue.length;
  process.stderr.write(
    `Summarizing ${turns.length} messages (${(chars / 1024).toFixed(0)} KB) with ${model}…\n`,
  );
  brief = summarize(dialogue, model);
  if (!brief) {
    process.stderr.write("No summarizer available — falling back to the full transcript.\n");
  }
}

const state = repoState();
const lines = [
  "# Handoff",
  "",
  `From a **${session.source}** session, exported ${new Date().toLocaleString()}.`,
  `Project: \`${REPO}\``,
  "",
  brief
    ? `Summarized by ${brief.by}. Run \`handoff --full\` for the verbatim transcript.`
    : "Verbatim dialogue; tool calls and their output are omitted.",
  "",
];

if (state) {
  lines.push("## Repository state", "");
  lines.push(`- Branch: \`${state.branch}\``);
  lines.push(`- Uncommitted: ${state.dirty ? `\n\n\`\`\`\n${state.dirty}\n\`\`\`` : "clean"}`);
  if (state.commits) lines.push("", "Recent commits:", "", "```", state.commits, "```");
  lines.push("");
}

if (brief) {
  lines.push(brief.text, "");
} else {
  lines.push("## Conversation", "");
  for (const t of turns) {
    lines.push(t.role === "user" ? "### User" : "### Agent", "", t.text, "");
  }
}

const out = lines.join("\n");

if (has("stdout")) {
  process.stdout.write(out);
  process.exit(0);
}

const target = join(REPO, "HANDOFF.md");
writeFileSync(target, out);

// A personal handoff file has no business in someone else's PR.
const gitDir = sh("git", ["rev-parse", "--git-dir"], REPO);
if (gitDir) {
  const exclude = join(gitDir.startsWith("/") ? gitDir : join(REPO, gitDir), "info", "exclude");
  try {
    if (!readFileSync(exclude, "utf8").split("\n").includes("HANDOFF.md")) {
      appendFileSync(exclude, "HANDOFF.md\n");
    }
  } catch {
    /* no exclude file; not worth failing over */
  }
}

const kb = (Buffer.byteLength(out) / 1024).toFixed(1);
const how = brief ? `summarized from ${turns.length} messages` : `${turns.length} messages verbatim`;
console.log(`Wrote HANDOFF.md — ${how} (${session.source}), ${kb} KB`);
console.log("");
console.log("Continue elsewhere:");
console.log('  claude       "read HANDOFF.md and continue where we left off"');
console.log('  codex        "read HANDOFF.md and continue where we left off"');
console.log('  cursor-agent "read HANDOFF.md and continue where we left off"');
